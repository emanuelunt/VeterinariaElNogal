@model VeterinariaGestion.Web.Models.PaginatedList<VeterinariaGestion.Core.Entities.Venta>
@{
    ViewData["Title"] = "Ventas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-cart3 text-warning"></i> Ventas</h2>
    <a asp-action="Crear" class="btn btn-warning">
        <i class="bi bi-plus-circle"></i> Nueva Venta
    </a>
</div>

<!-- Filtros -->
<form method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-md-5">
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" name="buscar" class="form-control"   value="@ViewBag.Buscar"
                       placeholder="Buscar por N° venta o cliente..." />
            </div>
        </div>
        <div class="col-md-3">
            <select name="estado" class="form-select">
                <option value="">-- Todos los estados --</option>
                @foreach (var e in ViewBag.Estados as List<string>)
                {
                    if (ViewBag.Estado == e)
                    {
                        <option value="@e" selected>@e</option>
                    }
                    else
                    {
                        <option value="@e">@e</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-auto">
            <button type="submit" class="btn btn-outline-warning">
                <i class="bi bi-funnel"></i> Filtrar
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x"></i> Limpiar
            </a>
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No se encontraron ventas.
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-2">
        <small class="text-muted">
            Mostrando <strong>@Model.Count</strong> de
            <strong>@Model.TotalCount</strong> ventas
            — Página <strong>@Model.PageIndex</strong> de
            <strong>@Model.TotalPages</strong>
        </small>
    </div>

    <table class="table table-striped table-hover table-bordered align-middle">
        <thead class="table-warning">
            <tr>
                <th>N° Venta</th>
                <th>Fecha</th>
                <th>Cliente</th>
                <th class="text-end">Subtotal</th>
                <th class="text-end">Descuento</th>
                <th class="text-end">Total</th>
                <th>Forma Pago</th>
                <th class="text-center">Estado</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var v in Model)
            {
                <tr class="@(v.EstadoPago == "Anulado" ? "table-secondary text-muted" : "")">
                    <td>
                        <strong class="text-warning">@(v.NumeroVenta ?? "-")</strong>
                    </td>
                    <td>@(v.Fecha?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                    <td>
                        @if (v.Cliente is not null)
                        {
                            <a asp-controller="Clientes"       asp-action="Detalle"             asp-route-id="@v.Cliente.IdCliente"
                                   class="text-decoration-none">
                                @v.Cliente.NombreCompleto
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">Consumidor Final</span>
                        }
                    </td>
                    <td class="text-end">$@v.SubTotal.ToString("N2")</td>
                    <td class="text-end text-danger">
                        @if (v.Descuento > 0)
                        {
                            <span>-$@v.Descuento.ToString("N2")</span>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td class="text-end fw-bold text-success">
                        $@v.Total.ToString("N2")
                    </td>
                    <td>
                        <span class="badge bg-secondary">@(v.FormaPago ?? "-")</span>
                    </td>
                    <td class="text-center">
                        @{
                            var badgeClass = v.EstadoPago switch
                            {
                                "Pagado" => "bg-success",
                                "Pendiente" => "bg-warning text-dark",
                                "Parcial" => "bg-info",
                                "Anulado" => "bg-danger",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @badgeClass">
                            @(v.EstadoPago ?? "-")
                        </span>
                    </td>
                    <td class="text-center">
                        <a asp-action="Detalle" asp-route-id="@v.IdVenta"                           class="btn btn-sm btn-info text-white"
                               title="Ver detalle">
                            <i class="bi bi-eye"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Paginador -->
    @if (Model.TotalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="1"            asp-route-buscar="@ViewBag.Buscar"
                           asp-route-estado="@ViewBag.Estado">
                        <i class="bi bi-chevron-double-left"></i>
                    </a>
                </li>
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link"     asp-action="Index"    asp-route-pagina="@(Model.PageIndex - 1)"
                           asp-route-buscar="@ViewBag.Buscar"         asp-route-estado="@ViewBag.Estado">
                        <i class="bi bi-chevron-left"></i> Anterior
                    </a>
                </li>
                @{
                    int inicio = Math.Max(1, Model.PageIndex - 2);
                    int fin = Math.Min(Model.TotalPages, inicio + 4);
                }
                @for (int i = inicio; i <= fin; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link"               asp-action="Index"                 asp-route-pagina="@i"                    asp-route-buscar="@ViewBag.Buscar"
                           asp-route-estado="@ViewBag.Estado">@i</a>
                    </li>
                }
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link"             asp-action="Index"            asp-route-pagina="@(Model.PageIndex + 1)"
                           asp-route-buscar="@ViewBag.Buscar"                 asp-route-estado="@ViewBag.Estado">
                        Siguiente <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link"    asp-action="Index"  asp-route-pagina="@Model.TotalPages"
                           asp-route-buscar="@ViewBag.Buscar"        asp-route-estado="@ViewBag.Estado">
                        <i class="bi bi-chevron-double-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
}