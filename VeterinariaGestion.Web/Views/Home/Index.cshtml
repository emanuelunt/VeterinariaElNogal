@{
    ViewData["Title"] = "Inicio";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-house text-success"></i> Panel Principal</h2>
    <span class="text-muted">@DateTime.Now.ToString("dddd, dd 'de' MMMM 'de' yyyy")</span>
</div>

<!-- Tarjetas de resumen -->
<div class="row g-4 mb-4">
    <div class="col-md-4 col-lg-2">
        <div class="card shadow-sm border-success h-100">
            <div class="card-body text-center">
                <i class="bi bi-people display-5 text-success"></i>
                <h3 class="mt-2 text-success">@ViewBag.TotalClientes</h3>
                <p class="text-muted mb-0">Clientes</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card shadow-sm border-primary h-100">
            <div class="card-body text-center">
                <i class="bi bi-box-seam display-5 text-primary"></i>
                <h3 class="mt-2 text-primary">@ViewBag.TotalProductos</h3>
                <p class="text-muted mb-0">Productos</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card shadow-sm border-info h-100">
            <div class="card-body text-center">
                <i class="bi bi-heart-pulse display-5 text-info"></i>
                <h3 class="mt-2 text-info">@ViewBag.TotalMascotas</h3>
                <p class="text-muted mb-0">Mascotas</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card shadow-sm border-warning h-100">
            <div class="card-body text-center">
                <i class="bi bi-cart3 display-5 text-warning"></i>
                <h3 class="mt-2 text-warning">@ViewBag.TotalVentas</h3>
                <p class="text-muted mb-0">Ventas</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card shadow-sm border-danger h-100">
            <div class="card-body text-center">
                <i class="bi bi-exclamation-triangle display-5 text-danger"></i>
                <h3 class="mt-2 text-danger">@ViewBag.StockBajo</h3>
                <p class="text-muted mb-0">Stock Bajo</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card shadow-sm border-secondary h-100">
            <div class="card-body text-center">
                <i class="bi bi-calendar-check display-5 text-secondary"></i>
                <h3 class="mt-2 text-secondary">@ViewBag.TurnosPendientes</h3>
                <p class="text-muted mb-0">Turnos Hoy</p>
            </div>
        </div>
    </div>
</div>

<!-- Accesos rápidos -->
<h5 class="text-muted mb-3">Accesos Rápidos</h5>
<div class="row g-3">
    <div class="col-md-3">
        <a asp-controller="Clientes" asp-action="Crear"
           class="btn btn-outline-success w-100 py-3">
            <i class="bi bi-person-plus d-block fs-3 mb-1"></i>
            Nuevo Cliente
        </a>
    </div>
    <div class="col-md-3">
        <a asp-controller="Ventas" asp-action="Crear"
           class="btn btn-outline-warning w-100 py-3">
            <i class="bi bi-cart-plus d-block fs-3 mb-1"></i>
            Nueva Venta
        </a>
    </div>
    <div class="col-md-3">
        <a asp-controller="Turnos" asp-action="Crear"
           class="btn btn-outline-info w-100 py-3">
            <i class="bi bi-calendar-plus d-block fs-3 mb-1"></i>
            Nuevo Turno
        </a>
    </div>
    <div class="col-md-3">
        <a asp-controller="Productos" asp-action="Crear"
           class="btn btn-outline-primary w-100 py-3">
            <i class="bi bi-plus-square d-block fs-3 mb-1"></i>
            Nuevo Producto
        </a>
    </div>
</div>