@model VeterinariaGestion.Core.Entities.Usuario
@{
    ViewData["Title"] = "Editar Usuario";
}

<h2 class="mb-4">
    <i class="bi bi-person-gear text-warning"></i> Editar Usuario
</h2>

<div class="card shadow-sm" style="max-width:700px">
    <div class="card-body">
        <form asp-action="Editar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdUsuario" />
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger"></div>
            }

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="NombreUsuario" class="form-label fw-bold"></label>
                    <input asp-for="NombreUsuario" class="form-control" required />
                    <span asp-validation-for="NombreUsuario" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label fw-bold"></label>
                    <input asp-for="Email" class="form-control" type="email" required />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Activo" class="form-label fw-bold"></label>
                    <select asp-for="Activo" class="form-select">
                        <option value="1">Activo</option>
                        <option value="0">Inactivo</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="FechaCreacion" class="form-label fw-bold"></label>
                    <input asp-for="FechaCreacion" class="form-control" readonly />
                </div>
            </div>

            <hr />
            <h6 class="mb-3">Cambiar Contraseña (opcional)</h6>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Nueva Contraseña</label>
                    <input name="nuevaPassword" class="form-control" type="password" minlength="6" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Confirmar Nueva Contraseña</label>
                    <input name="confirmarPassword" class="form-control" type="password" minlength="6" />
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-check-circle"></i> Actualizar
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
