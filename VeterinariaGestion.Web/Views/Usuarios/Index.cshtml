@model VeterinariaGestion.Web.Models.PaginatedList<VeterinariaGestion.Core.Entities.Usuario>
@{
    ViewData["Title"] = "Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-badge text-primary"></i> Usuarios</h2>
    <a asp-action="Crear" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nuevo Usuario
    </a>
</div>

<form method="get" class="mb-4">
    <div class="input-group" style="max-width:420px">
        <input type="text" name="buscar" class="form-control"
               value="@ViewBag.Buscar"
               placeholder="Buscar por usuario o email..." />
        <button type="submit" class="btn btn-outline-primary">
            <i class="bi bi-search"></i> Buscar
        </button>
        @if (!string.IsNullOrEmpty(ViewBag.Buscar as string))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x"></i> Limpiar
            </a>
        }
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No se encontraron usuarios.
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-2">
        <small class="text-muted">
            Mostrando <strong>@Model.Count</strong> de
            <strong>@Model.TotalCount</strong> usuarios
            - Pagina <strong>@Model.PageIndex</strong> de
            <strong>@Model.TotalPages</strong>
        </small>
    </div>

    <table class="table table-striped table-hover table-bordered align-middle">
        <thead class="table-primary">
            <tr>
                <th>Usuario</th>
                <th>Email</th>
                <th>Fecha Alta</th>
                <th class="text-center">Estado</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr class="@(u.Activo == 0 ? "table-secondary text-muted" : "")">
                    <td><strong>@u.NombreUsuario</strong></td>
                    <td>@u.Email</td>
                    <td>@(u.FechaCreacion?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                    <td class="text-center">
                        <form asp-action="CambiarEstado" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@u.IdUsuario" />
                            <button type="submit"
                                    class="btn btn-sm @(u.Activo == 1 ? "btn-success" : "btn-secondary")">
                                @(u.Activo == 1 ? "Activo" : "Inactivo")
                            </button>
                        </form>
                    </td>
                    <td class="text-center">
                        <a asp-action="Detalle" asp-route-id="@u.IdUsuario"
                           class="btn btn-sm btn-info text-white" title="Ver detalle">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Editar" asp-route-id="@u.IdUsuario"
                           class="btn btn-sm btn-warning" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="Eliminar" method="post" class="d-inline"
                              onsubmit="return confirm('Desea desactivar este usuario?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@u.IdUsuario" />
                            <button type="submit" class="btn btn-sm btn-danger" title="Desactivar">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Paginacion usuarios">
            <ul class="pagination justify-content-center">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="1" asp-route-buscar="@ViewBag.Buscar">
                        <i class="bi bi-chevron-double-left"></i>
                    </a>
                </li>
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@(Model.PageIndex - 1)" asp-route-buscar="@ViewBag.Buscar">
                        <i class="bi bi-chevron-left"></i> Anterior
                    </a>
                </li>
                @{
                    int inicio = Math.Max(1, Model.PageIndex - 2);
                    int fin = Math.Min(Model.TotalPages, inicio + 4);
                }
                @for (int i = inicio; i <= fin; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pagina="@i" asp-route-buscar="@ViewBag.Buscar">@i</a>
                    </li>
                }
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@(Model.PageIndex + 1)" asp-route-buscar="@ViewBag.Buscar">
                        Siguiente <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@Model.TotalPages" asp-route-buscar="@ViewBag.Buscar">
                        <i class="bi bi-chevron-double-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
}
