@model VeterinariaGestion.Core.Entities.Producto
@{
    ViewData["Title"] = "Nuevo Producto";
}

<h2 class="mb-4">
    <i class="bi bi-plus-square text-primary"></i> Nuevo Producto
</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Crear" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">

                <div class="col-md-4">
                    <label asp-for="Codigo" class="form-label"></label>
                    <input asp-for="Codigo" class="form-control" placeholder="Ej: PROD-001" />
                    <span asp-validation-for="Codigo" class="text-danger small"></span>
                </div>

                <div class="col-md-8">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" placeholder="Nombre del producto" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="IdTipo" class="form-label"></label>
                    <select asp-for="IdTipo" asp-items="ViewBag.Tipos" class="form-select">
                        <option value="">Seleccionar tipo...</option>
                    </select>
                    <span asp-validation-for="IdTipo" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="IdProveedor" class="form-label"></label>
                    <select asp-for="IdProveedor" asp-items="ViewBag.Proveedores" class="form-select">
                        <option value="">Seleccionar proveedor...</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label asp-for="Stock" class="form-label"></label>
                    <input asp-for="Stock" type="number" class="form-control"
                           min="0" placeholder="0" />
                    <span asp-validation-for="Stock" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="PrecioMinorista" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="PrecioMinorista" type="number" class="form-control"
                               min="0" step="0.01" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="PrecioMinorista" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="PrecioMayorista" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="PrecioMayorista" type="number" class="form-control"
                               min="0" step="0.01" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="PrecioMayorista" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Descripcion" class="form-label"></label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3"
                              placeholder="Descripción opcional del producto"></textarea>
                </div>

            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle"></i> Guardar
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}