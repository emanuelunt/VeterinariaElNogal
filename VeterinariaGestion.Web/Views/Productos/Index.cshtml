@model VeterinariaGestion.Web.Models.PaginatedList<VeterinariaGestion.Core.Entities.Producto>
@{
    ViewData["Title"] = "Productos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-box-seam text-primary"></i> Productos</h2>
    <a asp-action="Crear" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nuevo Producto
    </a>
</div>

<!-- Buscador -->
<form method="get" class="mb-4">
    <div class="input-group" style="max-width:450px">
        <input type="text" name="buscar" class="form-control"
               value="@ViewBag.Buscar"
               placeholder="Buscar por nombre o código..." />
        <button class="btn btn-outline-primary" type="submit">
            <i class="bi bi-search"></i> Buscar
        </button>
        @if (!string.IsNullOrEmpty(ViewBag.Buscar as string))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x"></i> Limpiar
            </a>
        }
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No hay productos registrados.
    </div>
}
else
{
    <div class="mb-2 text-muted small">
        Mostrando @Model.Count de @Model.TotalCount productos
        — Página @Model.PageIndex de @Model.TotalPages
    </div>

    <table class="table table-striped table-hover table-bordered align-middle">
        <thead class="table-primary">
            <tr>
                <th>Código</th>
                <th>Nombre</th>
                <th>Tipo</th>
                <th>Stock</th>
                <th>P. Minorista</th>
                <th>P. Mayorista</th>
                <th>Proveedor</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr class="@(p.Stock <= 5 ? "table-warning" : "")">
                    <td>@(p.Codigo ?? "-")</td>
                    <td><strong>@p.Nombre</strong></td>
                    <td>
                        <span class="badge bg-secondary">
                            @(p.Tipo?.Descripcion ?? "-")
                        </span>
                    </td>
                    <td class="text-center">
                        @if (p.Stock <= 5)
                        {
                            <span class="badge bg-warning text-dark">@p.Stock ⚠</span>
                        }
                        else
                        {
                            <span class="badge bg-success">@p.Stock</span>
                        }
                    </td>
                    <td class="text-end">$@p.PrecioMinorista.ToString("N2")</td>
                    <td class="text-end">$@p.PrecioMayorista.ToString("N2")</td>
                    <td>@(p.Proveedor?.RazonSocial ?? "-")</td>
                    <td class="text-center">
                        <a asp-action="Detalle" asp-route-id="@p.IdProducto"
                           class="btn btn-sm btn-info text-white" title="Ver">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Editar" asp-route-id="@p.IdProducto"
                           class="btn btn-sm btn-warning" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="Eliminar" method="post" class="d-inline"
                              onsubmit="return confirm('¿Eliminar este producto?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@p.IdProducto" />
                            <button type="submit" class="btn btn-sm btn-danger" title="Eliminar">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Paginador -->
    @if (Model.TotalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-pagina="@(Model.PageIndex - 1)"
                       asp-route-buscar="@ViewBag.Buscar">
                        <i class="bi bi-chevron-left"></i> Anterior
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-pagina="@i"
                           asp-route-buscar="@ViewBag.Buscar">@i</a>
                    </li>
                }

                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-pagina="@(Model.PageIndex + 1)"
                       asp-route-buscar="@ViewBag.Buscar">
                        Siguiente <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
}