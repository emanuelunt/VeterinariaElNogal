@model VeterinariaGestion.Web.Models.PaginatedList<VeterinariaGestion.Core.Entities.Especie>
@{
    ViewData["Title"] = "Especies";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-heart text-primary"></i> Especies</h2>
    <a asp-action="Crear" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nueva Especie
    </a>
</div>

<form method="get" class="mb-4">
    <div class="input-group" style="max-width:400px">
        <input type="text" name="buscar" class="form-control"
               value="@ViewBag.Buscar"
               placeholder="Buscar por descripcion..." />
        <button class="btn btn-outline-primary" type="submit">
            <i class="bi bi-search"></i> Buscar
        </button>
        @if (!string.IsNullOrEmpty(ViewBag.Buscar as string))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x"></i> Limpiar
            </a>
        }
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i>
        @if (!string.IsNullOrEmpty(ViewBag.Buscar as string))
        {
            <span>No se encontraron especies para "<strong>@ViewBag.Buscar</strong>".</span>
        }
        else
        {
            <span>No hay especies registradas.</span>
        }
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-2">
        <small class="text-muted">
            Mostrando <strong>@Model.Count</strong> de
            <strong>@Model.TotalCount</strong> especies
            - Pagina <strong>@Model.PageIndex</strong> de
            <strong>@Model.TotalPages</strong>
        </small>
    </div>

    <table class="table table-striped table-hover table-bordered align-middle">
        <thead class="table-primary">
            <tr>
                <th>#</th>
                <th>Descripcion</th>
                <th class="text-center">Mascotas Asociadas</th>
                <th class="text-center">Estado</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model)
            {
                <tr class="@(e.Estado == 0 ? "table-secondary text-muted" : "")">
                    <td class="text-muted small">@e.IdEspecie</td>
                    <td><strong>@(e.Descripcion ?? "-")</strong></td>
                    <td class="text-center">
                        <span class="badge bg-primary">
                            @e.Mascotas.Count(m => m.Estado == 1)
                        </span>
                    </td>
                    <td class="text-center">
                        <form asp-action="CambiarEstado" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@e.IdEspecie" />
                            <button type="submit"
                                    class="btn btn-sm @(e.Estado == 1 ? "btn-success" : "btn-secondary")"
                                    title="@(e.Estado == 1 ? "Desactivar" : "Activar")">
                                @if (e.Estado == 1)
                                {
                                    <i class="bi bi-check-circle"></i>
                                    <span>Activo</span>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle"></i>
                                    <span>Inactivo</span>
                                }
                            </button>
                        </form>
                    </td>
                    <td class="text-center">
                        <a asp-action="Detalle" asp-route-id="@e.IdEspecie"
                           class="btn btn-sm btn-info text-white" title="Ver detalle">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Editar" asp-route-id="@e.IdEspecie"
                           class="btn btn-sm btn-warning" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Eliminar" asp-route-id="@e.IdEspecie"
                           class="btn btn-sm btn-danger" title="Eliminar">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Paginacion especies">
            <ul class="pagination justify-content-center">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-pagina="1"
                       asp-route-buscar="@ViewBag.Buscar">
                        <i class="bi bi-chevron-double-left"></i>
                    </a>
                </li>
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-pagina="@(Model.PageIndex - 1)"
                       asp-route-buscar="@ViewBag.Buscar">
                        <i class="bi bi-chevron-left"></i> Anterior
                    </a>
                </li>

                @{
                    int inicio = Math.Max(1, Model.PageIndex - 2);
                    int fin = Math.Min(Model.TotalPages, inicio + 4);
                }
                @for (int i = inicio; i <= fin; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-pagina="@i"
                           asp-route-buscar="@ViewBag.Buscar">@i</a>
                    </li>
                }

                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-pagina="@(Model.PageIndex + 1)"
                       asp-route-buscar="@ViewBag.Buscar">
                        Siguiente <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-pagina="@Model.TotalPages"
                       asp-route-buscar="@ViewBag.Buscar">
                        <i class="bi bi-chevron-double-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
        <p class="text-center text-muted small">
            Pagina @Model.PageIndex de @Model.TotalPages
        </p>
    }
}
