@model VeterinariaGestion.Core.Entities.Especie
@{
    ViewData["Title"] = "Editar Especie";
}

<h2 class="mb-4">
    <i class="bi bi-pencil-square text-warning"></i> Editar Especie
</h2>

<div class="card shadow-sm" style="max-width:500px">
    <div class="card-body">
        <form asp-action="Editar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdEspecie" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label fw-bold"></label>
                <input asp-for="Descripcion" class="form-control" />
                <span asp-validation-for="Descripcion" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Estado" class="form-label fw-bold"></label>
                <select asp-for="Estado" class="form-select" style="max-width:200px">
                    <option value="1">Activo</option>
                    <option value="0">Inactivo</option>
                </select>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-check-circle"></i> Actualizar
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
