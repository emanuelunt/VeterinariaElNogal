@model VeterinariaGestion.Core.Entities.Proveedor
@{
    ViewData["Title"] = "Nuevo Proveedor";
}

<h2 class="mb-4">
    <i class="bi bi-truck text-success"></i> Nuevo Proveedor
</h2>

<div class="card shadow-sm" style="max-width:700px">
    <div class="card-body">
        <form asp-action="Crear" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">

                <div class="col-12">
                    <label asp-for="RazonSocial" class="form-label fw-bold"></label>
                    <input asp-for="RazonSocial" class="form-control"
                           placeholder="Razón social o nombre comercial" />
                    <span asp-validation-for="RazonSocial" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CuilCuit" class="form-label fw-bold"></label>
                    <input asp-for="CuilCuit" class="form-control"
                           placeholder="Ej: 30-12345678-9" />
                    <span asp-validation-for="CuilCuit" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Telefono" class="form-label fw-bold"></label>
                    <input asp-for="Telefono" class="form-control"
                           placeholder="Ej: 011-1234-5678" />
                    <span asp-validation-for="Telefono" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Email" class="form-label fw-bold"></label>
                    <input asp-for="Email" type="email" class="form-control"
                           placeholder="proveedor@email.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-circle"></i> Guardar
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}