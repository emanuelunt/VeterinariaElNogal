@model VeterinariaGestion.Core.Entities.Proveedor
@{
    ViewData["Title"] = "Detalle del Proveedor";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-truck text-success"></i> @Model.RazonSocial</h2>
    <div class="d-flex gap-2">
        <a asp-action="Editar" asp-route-id="@Model.IdProveedor" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Editar
        </a>
        <form asp-action="CambiarEstado" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.IdProveedor" />
            <button type="submit"
                    class="btn @(Model.Estado == 1 ? "btn-outline-danger" : "btn-outline-success")">
                @if (Model.Estado == 1)
                {
                    <i class="bi bi-x-circle"></i>
                    <span>Desactivar</span>
                }
                else
                {
                    <i class="bi bi-check-circle"></i>
                    <span>Activar</span>
                }
            </button>
        </form>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>
</div>

<div class="row g-4">

    <!-- Datos del proveedor -->
    <div class="col-md-5">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-success text-white">
                <i class="bi bi-building"></i> Datos del Proveedor
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Razón Social</dt>
                    <dd class="col-sm-7"><strong>@Model.RazonSocial</strong></dd>

                    <dt class="col-sm-5">CUIL/CUIT</dt>
                    <dd class="col-sm-7">@(Model.CuilCuit ?? "-")</dd>

                    <dt class="col-sm-5">Teléfono</dt>
                    <dd class="col-sm-7">@(Model.Telefono ?? "-")</dd>

                    <dt class="col-sm-5">Email</dt>
                    <dd class="col-sm-7">@(Model.Email ?? "-")</dd>

                    <dt class="col-sm-5">Fecha de Alta</dt>
                    <dd class="col-sm-7">
                        @(Model.FechaAlta?.ToString("dd/MM/yyyy") ?? "-")
                    </dd>

                    <dt class="col-sm-5">Estado</dt>
                    <dd class="col-sm-7">
                        <span class="badge @(Model.Estado == 1 ? "bg-success" : "bg-secondary")">
                            @(Model.Estado == 1 ? "Activo" : "Inactivo")
                        </span>
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <!-- Productos asociados -->
    <div class="col-md-7">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <span><i class="bi bi-box-seam"></i> Productos Asociados</span>
                <span class="badge bg-light text-dark">
                    @Model.Productos.Count(p => p.Estado == 1) activos
                </span>
            </div>
            <div class="card-body p-0">
                @if (!Model.Productos.Any())
                {
                    <p class="text-muted p-3 mb-0">
                        <i class="bi bi-info-circle"></i>
                        Sin productos asociados.
                    </p>
                }
                else
                {
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Código</th>
                                <th>Nombre</th>
                                <th class="text-center">Stock</th>
                                <th class="text-end">P. Minorista</th>
                                <th class="text-center">Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var prod in Model.Productos.OrderBy(p => p.Nombre))
                            {
                                <tr class="@(prod.Estado == 0 ? "text-muted" : "")">
                                    <td>@(prod.Codigo ?? "-")</td>
                                    <td>@prod.Nombre</td>
                                    <td class="text-center">
                                        <span class="badge @(prod.Stock <= 5 ? "bg-warning text-dark" : "bg-success")">
                                            @prod.Stock
                                        </span>
                                    </td>
                                    <td class="text-end">$@prod.PrecioMinorista.ToString("N2")</td>
                                    <td class="text-center">
                                        <span class="badge @(prod.Estado == 1 ? "bg-success" : "bg-secondary")">
                                            @(prod.Estado == 1 ? "Activo" : "Inactivo")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

</div>