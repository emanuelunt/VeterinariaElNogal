@model VeterinariaGestion.Core.Entities.Proveedor
@{
    ViewData["Title"] = "Editar Proveedor";
}

<h2 class="mb-4">
    <i class="bi bi-pencil-square text-warning"></i> Editar Proveedor
</h2>

<div class="card shadow-sm" style="max-width:700px">
    <div class="card-body">
        <form asp-action="Editar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdProveedor" />
            <input type="hidden" asp-for="FechaAlta" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">

                <div class="col-12">
                    <label asp-for="RazonSocial" class="form-label fw-bold"></label>
                    <input asp-for="RazonSocial" class="form-control" />
                    <span asp-validation-for="RazonSocial" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CuilCuit" class="form-label fw-bold"></label>
                    <input asp-for="CuilCuit" class="form-control" />
                    <span asp-validation-for="CuilCuit" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Telefono" class="form-label fw-bold"></label>
                    <input asp-for="Telefono" class="form-control" />
                </div>

                <div class="col-md-8">
                    <label asp-for="Email" class="form-label fw-bold"></label>
                    <input asp-for="Email" type="email" class="form-control" />
                </div>

                <div class="col-md-4">
                    <label asp-for="Estado" class="form-label fw-bold"></label>
                    <select asp-for="Estado" class="form-select">
                        <option value="1">Activo</option>
                        <option value="0">Inactivo</option>
                    </select>
                </div>

            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-check-circle"></i> Actualizar
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}