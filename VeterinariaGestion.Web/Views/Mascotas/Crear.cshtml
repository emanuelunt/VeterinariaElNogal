@model VeterinariaGestion.Core.Entities.Mascota
@{
    ViewData["Title"] = "Nueva Mascota";
}

<h2 class="mb-4">
    <i class="bi bi-heart-pulse text-info"></i> Nueva Mascota
</h2>

<div class="card shadow-sm" style="max-width:700px">
    <div class="card-body">
        <form asp-action="Crear" method="post">
            @Html.AntiForgeryToken()
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger"></div>
            }

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Nombre" class="form-label fw-bold"></label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ej: Luna, Max..." required />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Sexo" class="form-label fw-bold"></label>
                    <select asp-for="Sexo" class="form-select" asp-items="ViewBag.Sexos">
                        <option value="">Seleccione...</option>
                    </select>
                    <span asp-validation-for="Sexo" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="IdCliente" class="form-label fw-bold"></label>
                    <select asp-for="IdCliente" class="form-select" asp-items="ViewBag.Clientes" required>
                        <option value="0">Seleccione cliente...</option>
                    </select>
                    <span asp-validation-for="IdCliente" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="IdEspecie" class="form-label fw-bold"></label>
                    <select asp-for="IdEspecie" class="form-select" asp-items="ViewBag.Especies" required>
                        <option value="0">Seleccione especie...</option>
                    </select>
                    <span asp-validation-for="IdEspecie" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="FechaNaci" class="form-label fw-bold"></label>
                    <input asp-for="FechaNaci" class="form-control" type="date" />
                    <span asp-validation-for="FechaNaci" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-info text-white">
                    <i class="bi bi-check-circle"></i> Guardar
                </button>
                <a asp-action="Index" asp-route-idCliente="@Model.IdCliente" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
