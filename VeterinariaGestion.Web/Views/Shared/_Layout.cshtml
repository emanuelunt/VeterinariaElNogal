<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Veterinaria</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-success">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                🐾 El Nogal
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="nav">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-box-seam"></i> Productos
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Productos" asp-action="Index">Listado</a></li>
                                <li><a class="dropdown-item" asp-controller="Productos" asp-action="Crear">Nuevo</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-people"></i> Clientes
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Clientes" asp-action="Index">Listado</a></li>
                                <li><a class="dropdown-item" asp-controller="Clientes" asp-action="Crear">Nuevo</a></li>
                            </ul>
                        </li>



                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-box-seam"></i> Productos
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-controller="Productos" asp-action="Index">
                                        <i class="bi bi-list"></i> Listado
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Productos" asp-action="Crear">
                                        <i class="bi bi-plus"></i> Nuevo
                                    </a>
                                </li>
                                <li>
                                    <hr class="dropdown-divider">
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Tipos" asp-action="Index">
                                        <i class="bi bi-tags"></i> Tipos
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Proveedores" asp-action="Index">
                                        <i class="bi bi-truck"></i> Proveedores
                                    </a>
                                </li>
                            </ul>
                        </li>




                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-cart3"></i> Ventas
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Ventas" asp-action="Index">Listado</a></li>
                                <li><a class="dropdown-item" asp-controller="Ventas" asp-action="Crear">Nueva Venta</a></li>
                                <li><a class="dropdown-item" asp-controller="Cuotas" asp-action="Index">Cuotas</a></li>
                                <li><a class="dropdown-item" asp-controller="CuentasCorrientes" asp-action="Index">Cuenta Corriente</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-heart-pulse"></i> Clínica
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Especies" asp-action="Index">Especies</a></li>
                                <li><a class="dropdown-item" asp-controller="Mascotas" asp-action="Index">Mascotas</a></li>
                                <li><a class="dropdown-item" asp-controller="Turnos" asp-action="Index">Turnos</a></li>
                                <li><a class="dropdown-item" asp-controller="Historial" asp-action="Index">Historiales</a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Usuarios" asp-action="Index">
                                <i class="bi bi-person-gear"></i> Usuarios
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-outline-light btn-sm">
                                    <i class="bi bi-box-arrow-right"></i> @User.Identity.Name
                                </button>
                            </form>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        @if (TempData["Exito"] is string exito)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="bi bi-check-circle"></i> @exito
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="bi bi-exclamation-triangle"></i> @error
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
