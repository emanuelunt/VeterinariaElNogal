@model VeterinariaGestion.Core.Entities.Cliente
@{
    ViewData["Title"] = "Detalle del Cliente";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person text-success"></i> @Model.NombreCompleto</h2>
    <div class="d-flex gap-2">
        <a asp-action="Editar" asp-route-id="@Model.IdCliente" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Editar
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <i class="bi bi-person-vcard"></i> Datos Personales
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Apellido y Nombre</dt>
                    <dd class="col-sm-8">@Model.NombreCompleto</dd>
                    <dt class="col-sm-4">DNI/CUIL</dt>
                    <dd class="col-sm-8">@(Model.CuilDni ?? "-")</dd>
                    <dt class="col-sm-4">Teléfono</dt>
                    <dd class="col-sm-8">@(Model.Telefono ?? "-")</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@(Model.Email ?? "-")</dd>
                    <dt class="col-sm-4">Dirección</dt>
                    <dd class="col-sm-8">@(Model.Direccion ?? "-")</dd>
                    <dt class="col-sm-4">Alta</dt>
                    <dd class="col-sm-8">@(Model.FechaAlta?.ToString("dd/MM/yyyy") ?? "-")</dd>
                    <dt class="col-sm-4">Estado</dt>
                    <dd class="col-sm-8">
                        <span class="badge @(Model.Estado == 1 ? "bg-success" : "bg-danger")">
                            @(Model.Estado == 1 ? "Activo" : "Inactivo")
                        </span>
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <!-- Mascotas del cliente -->
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-info text-white d-flex justify-content-between">
                <span><i class="bi bi-heart-pulse"></i> Mascotas</span>
                <a asp-controller="Mascotas" asp-action="Crear"
                   asp-route-idCliente="@Model.IdCliente"
                   class="btn btn-sm btn-light">
                    <i class="bi bi-plus"></i> Nueva
                </a>
            </div>
            <div class="card-body p-0">
                @if (!Model.Mascotas.Any())
                {
                    <p class="text-muted p-3 mb-0">Sin mascotas registradas.</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>Especie</th>
                                <th>Sexo</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in Model.Mascotas.Where(m => m.Estado == 1))
                            {
                                <tr>
                                    <td>@m.Nombre</td>
                                    <td>@(m.Especie?.Descripcion ?? "-")</td>
                                    <td>@(m.Sexo ?? "-")</td>
                                    <td>
                                        <a asp-controller="Mascotas"
                                           asp-action="Detalle"
                                           asp-route-id="@m.IdMascota"
                                           class="btn btn-sm btn-info text-white">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>