@model VeterinariaGestion.Core.Entities.Cliente
@{
    ViewData["Title"] = "Editar Cliente";
}

<h2 class="mb-4">
    <i class="bi bi-pencil-square text-warning"></i> Editar Cliente
</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Editar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdCliente" />
            <input type="hidden" asp-for="FechaAlta" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Apellido" class="form-label"></label>
                    <input asp-for="Apellido" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="CuilDni" class="form-label"></label>
                    <input asp-for="CuilDni" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Telefono" class="form-label"></label>
                    <input asp-for="Telefono" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" type="email" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Direccion" class="form-label"></label>
                    <input asp-for="Direccion" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Estado" class="form-label"></label>
                    <select asp-for="Estado" class="form-select">
                        <option value="1">Activo</option>
                        <option value="0">Inactivo</option>
                    </select>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-check-circle"></i> Actualizar
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Cancelar
                </a>
            </div>
        </form>
    </div>
</div>