@model VeterinariaGestion.Web.Models.PaginatedList<VeterinariaGestion.Core.Entities.Cliente>
@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people text-success"></i> Clientes</h2>
    <a asp-action="Crear" class="btn btn-success">
        <i class="bi bi-person-plus"></i> Nuevo Cliente
    </a>
</div>

<!-- Buscador -->
<form method="get" class="mb-4">
    <div class="input-group" style="max-width:500px">
        <input type="text" name="buscar" class="form-control"
               value="@ViewBag.Buscar"
               placeholder="Buscar por nombre, apellido, DNI, teléfono o email..." />
        <button class="btn btn-outline-success" type="submit">
            <i class="bi bi-search"></i> Buscar
        </button>
        @if (!string.IsNullOrEmpty(ViewBag.Buscar as string))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x"></i> Limpiar
            </a>
        }
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i>
        @if (!string.IsNullOrEmpty(ViewBag.Buscar as string))
        {
            <span>No se encontraron clientes para "<strong>@ViewBag.Buscar</strong>".</span>
        }
        else
        {
            <span>No hay clientes registrados.</span>
        }
    </div>
}
else
{
    <!-- Info de paginado -->
    <div class="d-flex justify-content-between align-items-center mb-2">
        <small class="text-muted">
            Mostrando <strong>@Model.Count</strong> de
            <strong>@Model.TotalCount</strong> clientes
            — Página <strong>@Model.PageIndex</strong> de
            <strong>@Model.TotalPages</strong>
        </small>
        <small class="text-muted">
            @Model.TotalCount cliente(s) en total
        </small>
    </div>

    <table class="table table-striped table-hover table-bordered align-middle">
        <thead class="table-success">
            <tr>
                <th>Apellido y Nombre</th>
                <th>DNI/CUIL</th>
                <th>Teléfono</th>
                <th>Email</th>
                <th>Alta</th>
                <th class="text-center">Estado</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr class="@(c.Estado == 0 ? "table-secondary text-muted" : "")">
                    <td>
                        <strong>@c.NombreCompleto</strong>
                    </td>
                    <td>@(c.CuilDni ?? "-")</td>
                    <td>
                        @if (!string.IsNullOrEmpty(c.Telefono))
                        {
                            <a href="tel:@c.Telefono" class="text-decoration-none">
                                <i class="bi bi-telephone"></i> @c.Telefono
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(c.Email))
                        {
                            <a href="mailto:@c.Email" class="text-decoration-none">
                                <i class="bi bi-envelope"></i> @c.Email
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>@(c.FechaAlta?.ToString("dd/MM/yyyy") ?? "-")</td>
                    <td class="text-center">
                        <!-- Toggle estado desde listado -->
                        <form asp-action="CambiarEstado" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@c.IdCliente" />
                            <button type="submit"
                                    class="btn btn-sm @(c.Estado == 1 ? "btn-success" : "btn-secondary")"
                                    title="@(c.Estado == 1 ? "Desactivar" : "Activar")">
                                @if (c.Estado == 1)
                                {
                                    <i class="bi bi-check-circle"></i>
                                    <span>Activo</span>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle"></i>
                                    <span>Inactivo</span>
                                }
                            </button>
                        </form>
                    </td>
                    <td class="text-center">
                        <a asp-action="Detalle" asp-route-id="@c.IdCliente"
                           class="btn btn-sm btn-info text-white" title="Ver detalle">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Editar" asp-route-id="@c.IdCliente"
                           class="btn btn-sm btn-warning" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="Eliminar" method="post" class="d-inline"
                              onsubmit="return confirm('¿Desactivar este cliente?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@c.IdCliente" />
                            <button type="submit" class="btn btn-sm btn-danger" title="Eliminar">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Paginador -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Paginación clientes">
            <ul class="pagination justify-content-center">

                <!-- Primera página -->
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-pagina="1"
                       asp-route-buscar="@ViewBag.Buscar"
                       title="Primera página">
                        <i class="bi bi-chevron-double-left"></i>
                    </a>
                </li>

                <!-- Página anterior -->
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-pagina="@(Model.PageIndex - 1)"
                       asp-route-buscar="@ViewBag.Buscar">
                        <i class="bi bi-chevron-left"></i> Anterior
                    </a>
                </li>

                <!-- Números de página (máx 5 visibles) -->
                @{
                    int inicio = Math.Max(1, Model.PageIndex - 2);
                    int fin    = Math.Min(Model.TotalPages, inicio + 4);
                }
                @for (int i = inicio; i <= fin; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-pagina="@i"
                           asp-route-buscar="@ViewBag.Buscar">@i</a>
                    </li>
                }

                <!-- Página siguiente -->
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-pagina="@(Model.PageIndex + 1)"
                       asp-route-buscar="@ViewBag.Buscar">
                        Siguiente <i class="bi bi-chevron-right"></i>
                    </a>
                </li>

                <!-- Última página -->
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-pagina="@Model.TotalPages"
                       asp-route-buscar="@ViewBag.Buscar"
                       title="Última página">
                        <i class="bi bi-chevron-double-right"></i>
                    </a>
                </li>

            </ul>
        </nav>

        <p class="text-center text-muted small">
            Página @Model.PageIndex de @Model.TotalPages
        </p>
    }
}
