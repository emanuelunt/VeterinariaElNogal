@model VeterinariaGestion.Core.Entities.CuentaCorriente
@{
    ViewData["Title"] = "Detalle Movimiento";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
        <i class="bi bi-cash-coin text-primary"></i>
        Movimiento #@Model.IdCuentaCorriente
    </h2>
    <div class="d-flex gap-2">
        <a asp-action="Editar" asp-route-id="@Model.IdCuentaCorriente" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Editar
        </a>
        <form asp-action="Eliminar" method="post" class="d-inline"
              onsubmit="return confirm('Desea eliminar este movimiento?')">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.IdCuentaCorriente" />
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash"></i> Eliminar
            </button>
        </form>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-info-circle"></i> Datos del Movimiento
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Fecha</dt>
                    <dd class="col-sm-7">@(Model.FechaMovimiento?.ToString("dd/MM/yyyy") ?? "-")</dd>

                    <dt class="col-sm-5">Tipo</dt>
                    <dd class="col-sm-7">@(Model.TipoMovimiento ?? "-")</dd>

                    <dt class="col-sm-5">Concepto</dt>
                    <dd class="col-sm-7">@(Model.Concepto ?? "-")</dd>

                    <dt class="col-sm-5">Comprobante</dt>
                    <dd class="col-sm-7">@(Model.Comprobante ?? "-")</dd>

                    <dt class="col-sm-5">Estado Cuenta</dt>
                    <dd class="col-sm-7"><span class="badge bg-secondary">@(Model.EstadoCuenta ?? "-")</span></dd>

                    <dt class="col-sm-5">Vencimiento</dt>
                    <dd class="col-sm-7">@(Model.FechaVencimiento?.ToString("dd/MM/yyyy") ?? "-")</dd>

                    <dt class="col-sm-5">Observacion</dt>
                    <dd class="col-sm-7">@(Model.Observacion ?? "-")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-info text-white">
                <i class="bi bi-people"></i> Cliente
            </div>
            <div class="card-body">
                <p class="mb-1"><strong>@(Model.Cliente?.NombreCompleto ?? "-")</strong></p>
                <p class="mb-1">DNI/CUIL: @(Model.Cliente?.CuilDni ?? "-")</p>
                <p class="mb-0">
                    <a asp-controller="Clientes" asp-action="Detalle" asp-route-id="@Model.IdCliente">
                        Ver cliente
                    </a>
                </p>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <i class="bi bi-calculator"></i> Saldos
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span>Importe:</span>
                    <strong>@Model.Importe.ToString("N2")</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Saldo Anterior:</span>
                    <strong>@Model.SaldoAnterior.ToString("N2")</strong>
                </div>
                <div class="d-flex justify-content-between p-2 bg-light rounded">
                    <span class="fw-bold">Saldo Nuevo:</span>
                    <span class="fw-bold">@Model.SaldoNuevo.ToString("N2")</span>
                </div>

                @if (Model.IdVenta.HasValue)
                {
                    <hr />
                    <p class="mb-0">
                        Venta asociada:
                        <a asp-controller="Ventas" asp-action="Detalle" asp-route-id="@Model.IdVenta">
                            @(Model.Venta?.NumeroVenta ?? ("Venta #" + Model.IdVenta))
                        </a>
                    </p>
                }
            </div>
        </div>
    </div>
</div>
