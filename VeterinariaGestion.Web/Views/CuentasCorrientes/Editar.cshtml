@model VeterinariaGestion.Core.Entities.CuentaCorriente
@{
    ViewData["Title"] = "Editar Movimiento";
}

<h2 class="mb-4">
    <i class="bi bi-pencil-square text-warning"></i> Editar Movimiento de Cuenta Corriente
</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Editar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdCuentaCorriente" />
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger"></div>
            }

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="IdCliente" class="form-label fw-bold"></label>
                    <select asp-for="IdCliente" class="form-select" asp-items="ViewBag.Clientes" required>
                        <option value="0">Seleccione cliente...</option>
                    </select>
                    <span asp-validation-for="IdCliente" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="IdVenta" class="form-label fw-bold"></label>
                    <select asp-for="IdVenta" class="form-select" asp-items="ViewBag.Ventas">
                        <option value="">Sin venta asociada</option>
                    </select>
                    <span asp-validation-for="IdVenta" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="FechaMovimiento" class="form-label fw-bold"></label>
                    <input asp-for="FechaMovimiento" type="date" class="form-control" />
                    <span asp-validation-for="FechaMovimiento" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="TipoMovimiento" class="form-label fw-bold"></label>
                    <select asp-for="TipoMovimiento" class="form-select">
                        @foreach (var t in (List<string>)ViewBag.TiposMovimiento)
                        {
                            if (Model.TipoMovimiento == t)
                            {
                                <option value="@t" selected>@t</option>
                            }
                            else
                            {
                                <option value="@t">@t</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="TipoMovimiento" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Importe" class="form-label fw-bold"></label>
                    <input asp-for="Importe" class="form-control" type="number" step="0.01" min="0.01" required />
                    <span asp-validation-for="Importe" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="EstadoCuenta" class="form-label fw-bold"></label>
                    <select asp-for="EstadoCuenta" class="form-select">
                        @foreach (var e in (List<string>)ViewBag.EstadosCuenta)
                        {
                            if (Model.EstadoCuenta == e)
                            {
                                <option value="@e" selected>@e</option>
                            }
                            else
                            {
                                <option value="@e">@e</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="SaldoAnterior" class="form-label fw-bold"></label>
                    <input asp-for="SaldoAnterior" class="form-control" readonly />
                </div>
                <div class="col-md-4">
                    <label asp-for="SaldoNuevo" class="form-label fw-bold"></label>
                    <input asp-for="SaldoNuevo" class="form-control" readonly />
                </div>
                <div class="col-md-4">
                    <label asp-for="Estado" class="form-label fw-bold"></label>
                    <select asp-for="Estado" class="form-select">
                        <option value="1">Activo</option>
                        <option value="0">Inactivo</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Concepto" class="form-label fw-bold"></label>
                    <input asp-for="Concepto" class="form-control" />
                    <span asp-validation-for="Concepto" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Comprobante" class="form-label fw-bold"></label>
                    <input asp-for="Comprobante" class="form-control" />
                    <span asp-validation-for="Comprobante" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="FechaVencimiento" class="form-label fw-bold"></label>
                    <input asp-for="FechaVencimiento" type="date" class="form-control" />
                    <span asp-validation-for="FechaVencimiento" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Observacion" class="form-label fw-bold"></label>
                    <textarea asp-for="Observacion" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Observacion" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-check-circle"></i> Actualizar
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
