@model VeterinariaGestion.Web.Models.PaginatedList<VeterinariaGestion.Core.Entities.CuentaCorriente>
@{
    ViewData["Title"] = "Cuenta Corriente";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-cash-coin text-primary"></i> Cuenta Corriente</h2>
    <a asp-action="Crear" asp-route-idCliente="@ViewBag.IdCliente" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nuevo Movimiento
    </a>
</div>

<form method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-md-3">
            <input type="text" name="buscar" class="form-control"
                   value="@ViewBag.Buscar"
                   placeholder="Cliente, concepto, venta..." />
        </div>
        <div class="col-md-3">
            <select name="idCliente" class="form-select" asp-items="ViewBag.ClientesFiltro">
                <option value="">-- Todos los clientes --</option>
            </select>
        </div>
        <div class="col-md-2">
            <select name="tipoMovimiento" class="form-select">
                <option value="">-- Tipo --</option>
                @foreach (var t in (List<string>)ViewBag.TiposMovimiento)
                {
                    if ((string?)ViewBag.TipoMovimiento == t)
                    {
                        <option value="@t" selected>@t</option>
                    }
                    else
                    {
                        <option value="@t">@t</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="estadoCuenta" class="form-select">
                <option value="">-- Estado --</option>
                @foreach (var e in (List<string>)ViewBag.EstadosCuenta)
                {
                    if ((string?)ViewBag.EstadoCuenta == e)
                    {
                        <option value="@e" selected>@e</option>
                    }
                    else
                    {
                        <option value="@e">@e</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-outline-primary">
                <i class="bi bi-search"></i>
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x"></i>
            </a>
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No se encontraron movimientos.
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-2">
        <small class="text-muted">
            Mostrando <strong>@Model.Count</strong> de <strong>@Model.TotalCount</strong> movimientos
            - Pagina <strong>@Model.PageIndex</strong> de <strong>@Model.TotalPages</strong>
        </small>
    </div>

    <table class="table table-striped table-hover table-bordered align-middle">
        <thead class="table-primary">
            <tr>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Venta</th>
                <th>Tipo</th>
                <th>Concepto</th>
                <th class="text-end">Importe</th>
                <th class="text-end">Saldo Anterior</th>
                <th class="text-end">Saldo Nuevo</th>
                <th>Estado</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@(c.FechaMovimiento?.ToString("dd/MM/yyyy") ?? "-")</td>
                    <td>@(c.Cliente?.NombreCompleto ?? "-")</td>
                    <td>
                        @if (c.IdVenta.HasValue)
                        {
                            <a asp-controller="Ventas" asp-action="Detalle" asp-route-id="@c.IdVenta">
                                @(c.Venta?.NumeroVenta ?? ("Venta #" + c.IdVenta))
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        <span class="badge @(c.TipoMovimiento == "Credito" ? "bg-success" : "bg-warning text-dark")">
                            @(c.TipoMovimiento ?? "-")
                        </span>
                    </td>
                    <td>@(c.Concepto ?? "-")</td>
                    <td class="text-end">@c.Importe.ToString("N2")</td>
                    <td class="text-end">@c.SaldoAnterior.ToString("N2")</td>
                    <td class="text-end fw-bold">@c.SaldoNuevo.ToString("N2")</td>
                    <td>
                        <span class="badge bg-secondary">@(c.EstadoCuenta ?? "-")</span>
                    </td>
                    <td class="text-center">
                        <a asp-action="Detalle" asp-route-id="@c.IdCuentaCorriente"
                           class="btn btn-sm btn-info text-white" title="Ver detalle">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Editar" asp-route-id="@c.IdCuentaCorriente"
                           class="btn btn-sm btn-warning" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="Eliminar" method="post" class="d-inline"
                              onsubmit="return confirm('Desea eliminar este movimiento?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@c.IdCuentaCorriente" />
                            <button type="submit" class="btn btn-sm btn-danger" title="Eliminar">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Paginacion cuenta corriente">
            <ul class="pagination justify-content-center">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="1"
                       asp-route-buscar="@ViewBag.Buscar" asp-route-idCliente="@ViewBag.IdCliente"
                       asp-route-estadoCuenta="@ViewBag.EstadoCuenta" asp-route-tipoMovimiento="@ViewBag.TipoMovimiento">
                        <i class="bi bi-chevron-double-left"></i>
                    </a>
                </li>
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@(Model.PageIndex - 1)"
                       asp-route-buscar="@ViewBag.Buscar" asp-route-idCliente="@ViewBag.IdCliente"
                       asp-route-estadoCuenta="@ViewBag.EstadoCuenta" asp-route-tipoMovimiento="@ViewBag.TipoMovimiento">
                        <i class="bi bi-chevron-left"></i> Anterior
                    </a>
                </li>
                @{
                    int inicio = Math.Max(1, Model.PageIndex - 2);
                    int fin = Math.Min(Model.TotalPages, inicio + 4);
                }
                @for (int i = inicio; i <= fin; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pagina="@i"
                           asp-route-buscar="@ViewBag.Buscar" asp-route-idCliente="@ViewBag.IdCliente"
                           asp-route-estadoCuenta="@ViewBag.EstadoCuenta" asp-route-tipoMovimiento="@ViewBag.TipoMovimiento">@i</a>
                    </li>
                }
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@(Model.PageIndex + 1)"
                       asp-route-buscar="@ViewBag.Buscar" asp-route-idCliente="@ViewBag.IdCliente"
                       asp-route-estadoCuenta="@ViewBag.EstadoCuenta" asp-route-tipoMovimiento="@ViewBag.TipoMovimiento">
                        Siguiente <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@Model.TotalPages"
                       asp-route-buscar="@ViewBag.Buscar" asp-route-idCliente="@ViewBag.IdCliente"
                       asp-route-estadoCuenta="@ViewBag.EstadoCuenta" asp-route-tipoMovimiento="@ViewBag.TipoMovimiento">
                        <i class="bi bi-chevron-double-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
}
