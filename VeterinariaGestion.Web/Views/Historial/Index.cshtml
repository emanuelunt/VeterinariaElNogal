@model VeterinariaGestion.Web.Models.PaginatedList<VeterinariaGestion.Core.Entities.Historial>
@{
    ViewData["Title"] = "Historiales";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-journal-medical text-success"></i> Historiales</h2>
    <a asp-action="Crear" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Nuevo Historial
    </a>
</div>

<form method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-md-4">
            <input type="text" name="buscar" class="form-control"
                   value="@ViewBag.Buscar"
                   placeholder="Mascota, cliente, motivo, diagnostico..." />
        </div>
        <div class="col-md-3">
            <input type="date" name="fechaDesde" class="form-control" value="@ViewBag.FechaDesde" />
        </div>
        <div class="col-md-3">
            <input type="date" name="fechaHasta" class="form-control" value="@ViewBag.FechaHasta" />
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-outline-success">
                <i class="bi bi-search"></i>
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x"></i>
            </a>
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No se encontraron historiales.
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-2">
        <small class="text-muted">
            Mostrando <strong>@Model.Count</strong> de
            <strong>@Model.TotalCount</strong> historiales
            - Pagina <strong>@Model.PageIndex</strong> de
            <strong>@Model.TotalPages</strong>
        </small>
    </div>

    <table class="table table-striped table-hover table-bordered align-middle">
        <thead class="table-success">
            <tr>
                <th>Fecha</th>
                <th>Mascota</th>
                <th>Cliente</th>
                <th>Motivo</th>
                <th>Diagnostico</th>
                <th>Turno</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var h in Model)
            {
                <tr>
                    <td>@(h.FechaConsulta?.ToString("dd/MM/yyyy") ?? "-")</td>
                    <td>@(h.Mascota?.Nombre ?? "-")</td>
                    <td>@(h.Mascota?.Cliente?.NombreCompleto ?? "-")</td>
                    <td>@(h.MotivoConsulta ?? "-")</td>
                    <td>@(h.Diagnostico ?? "-")</td>
                    <td>
                        @if (h.IdTurno.HasValue)
                        {
                            <a asp-controller="Turnos" asp-action="Detalle" asp-route-id="@h.IdTurno">
                                #@h.IdTurno
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td class="text-center">
                        <a asp-action="Detalle" asp-route-id="@h.IdHistorial"
                           class="btn btn-sm btn-info text-white" title="Ver detalle">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Editar" asp-route-id="@h.IdHistorial"
                           class="btn btn-sm btn-warning" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="Eliminar" method="post" class="d-inline"
                              onsubmit="return confirm('Desea eliminar este historial?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@h.IdHistorial" />
                            <button type="submit" class="btn btn-sm btn-danger" title="Eliminar">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Paginacion historiales">
            <ul class="pagination justify-content-center">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="1"
                       asp-route-buscar="@ViewBag.Buscar"
                       asp-route-fechaDesde="@ViewBag.FechaDesde"
                       asp-route-fechaHasta="@ViewBag.FechaHasta">
                        <i class="bi bi-chevron-double-left"></i>
                    </a>
                </li>
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@(Model.PageIndex - 1)"
                       asp-route-buscar="@ViewBag.Buscar"
                       asp-route-fechaDesde="@ViewBag.FechaDesde"
                       asp-route-fechaHasta="@ViewBag.FechaHasta">
                        <i class="bi bi-chevron-left"></i> Anterior
                    </a>
                </li>
                @{
                    int inicio = Math.Max(1, Model.PageIndex - 2);
                    int fin = Math.Min(Model.TotalPages, inicio + 4);
                }
                @for (int i = inicio; i <= fin; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pagina="@i"
                           asp-route-buscar="@ViewBag.Buscar"
                           asp-route-fechaDesde="@ViewBag.FechaDesde"
                           asp-route-fechaHasta="@ViewBag.FechaHasta">@i</a>
                    </li>
                }
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@(Model.PageIndex + 1)"
                       asp-route-buscar="@ViewBag.Buscar"
                       asp-route-fechaDesde="@ViewBag.FechaDesde"
                       asp-route-fechaHasta="@ViewBag.FechaHasta">
                        Siguiente <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@Model.TotalPages"
                       asp-route-buscar="@ViewBag.Buscar"
                       asp-route-fechaDesde="@ViewBag.FechaDesde"
                       asp-route-fechaHasta="@ViewBag.FechaHasta">
                        <i class="bi bi-chevron-double-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
}
