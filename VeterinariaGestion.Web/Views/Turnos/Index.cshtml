@model VeterinariaGestion.Web.Models.PaginatedList<VeterinariaGestion.Core.Entities.Turno>
@{
    ViewData["Title"] = "Turnos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-calendar-check text-primary"></i> Turnos</h2>
    <a asp-action="Crear" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nuevo Turno
    </a>
</div>

<form method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-md-4">
            <input type="text" name="buscar" class="form-control"
                   value="@ViewBag.Buscar"
                   placeholder="Mascota, cliente, motivo..." />
        </div>
        <div class="col-md-3">
            <select name="estado" class="form-select">
                <option value="">-- Todos los estados --</option>
                @foreach (var e in (List<string>)ViewBag.EstadosTurno)
                {
                    if ((string?)ViewBag.Estado == e)
                    {
                        <option value="@e" selected>@e</option>
                    }
                    else
                    {
                        <option value="@e">@e</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3">
            <input type="date" name="fecha" class="form-control" value="@ViewBag.Fecha" />
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-outline-primary">
                <i class="bi bi-search"></i>
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x"></i>
            </a>
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No se encontraron turnos.
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-2">
        <small class="text-muted">
            Mostrando <strong>@Model.Count</strong> de
            <strong>@Model.TotalCount</strong> turnos
            - Pagina <strong>@Model.PageIndex</strong> de
            <strong>@Model.TotalPages</strong>
        </small>
    </div>

    <table class="table table-striped table-hover table-bordered align-middle">
        <thead class="table-primary">
            <tr>
                <th>Fecha</th>
                <th>Hora</th>
                <th>Mascota</th>
                <th>Cliente</th>
                <th>Estado</th>
                <th>Motivo</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model)
            {
                var badge = t.EstadoTurno switch
                {
                    "Pendiente" => "bg-warning text-dark",
                    "Confirmado" => "bg-info",
                    "Atendido" => "bg-success",
                    "Cancelado" => "bg-danger",
                    _ => "bg-secondary"
                };
                <tr>
                    <td>@(t.Fecha?.ToString("dd/MM/yyyy") ?? "-")</td>
                    <td>@(t.HoraTurno ?? "-")</td>
                    <td>@(t.Mascota?.Nombre ?? "-")</td>
                    <td>@(t.Mascota?.Cliente?.NombreCompleto ?? "-")</td>
                    <td><span class="badge @badge">@(t.EstadoTurno ?? "-")</span></td>
                    <td>@(t.Motivo ?? "-")</td>
                    <td class="text-center">
                        <a asp-action="Detalle" asp-route-id="@t.IdTurno"
                           class="btn btn-sm btn-info text-white" title="Ver detalle">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Editar" asp-route-id="@t.IdTurno"
                           class="btn btn-sm btn-warning" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="Eliminar" method="post" class="d-inline"
                              onsubmit="return confirm('Desea cancelar este turno?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@t.IdTurno" />
                            <button type="submit" class="btn btn-sm btn-danger" title="Cancelar">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Paginacion turnos">
            <ul class="pagination justify-content-center">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="1"
                       asp-route-buscar="@ViewBag.Buscar" asp-route-estado="@ViewBag.Estado" asp-route-fecha="@ViewBag.Fecha">
                        <i class="bi bi-chevron-double-left"></i>
                    </a>
                </li>
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@(Model.PageIndex - 1)"
                       asp-route-buscar="@ViewBag.Buscar" asp-route-estado="@ViewBag.Estado" asp-route-fecha="@ViewBag.Fecha">
                        <i class="bi bi-chevron-left"></i> Anterior
                    </a>
                </li>
                @{
                    int inicio = Math.Max(1, Model.PageIndex - 2);
                    int fin = Math.Min(Model.TotalPages, inicio + 4);
                }
                @for (int i = inicio; i <= fin; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pagina="@i"
                           asp-route-buscar="@ViewBag.Buscar" asp-route-estado="@ViewBag.Estado" asp-route-fecha="@ViewBag.Fecha">@i</a>
                    </li>
                }
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@(Model.PageIndex + 1)"
                       asp-route-buscar="@ViewBag.Buscar" asp-route-estado="@ViewBag.Estado" asp-route-fecha="@ViewBag.Fecha">
                        Siguiente <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@Model.TotalPages"
                       asp-route-buscar="@ViewBag.Buscar" asp-route-estado="@ViewBag.Estado" asp-route-fecha="@ViewBag.Fecha">
                        <i class="bi bi-chevron-double-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
}
