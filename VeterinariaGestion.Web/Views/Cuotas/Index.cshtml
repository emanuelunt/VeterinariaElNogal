@model VeterinariaGestion.Web.Models.PaginatedList<VeterinariaGestion.Core.Entities.Cuota>
@{
    ViewData["Title"] = "Cuotas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-calendar2-check text-info"></i> Cuotas</h2>
    <a asp-action="Crear" asp-route-idVenta="@ViewBag.IdVenta" class="btn btn-info text-white">
        <i class="bi bi-plus-circle"></i> Nueva Cuota
    </a>
</div>

<form method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-md-4">
            <input type="text" name="buscar" class="form-control"
                   value="@ViewBag.Buscar"
                   placeholder="Venta, cliente, estado..." />
        </div>
        <div class="col-md-3">
            <select name="idVenta" class="form-select" asp-items="ViewBag.VentasFiltro">
                <option value="">-- Todas las ventas --</option>
            </select>
        </div>
        <div class="col-md-3">
            <select name="estadoCuota" class="form-select">
                <option value="">-- Todos los estados --</option>
                @foreach (var e in (List<string>)ViewBag.EstadosCuota)
                {
                    if ((string?)ViewBag.EstadoCuota == e)
                    {
                        <option value="@e" selected>@e</option>
                    }
                    else
                    {
                        <option value="@e">@e</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-outline-info">
                <i class="bi bi-search"></i>
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x"></i>
            </a>
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No se encontraron cuotas.
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-2">
        <small class="text-muted">
            Mostrando <strong>@Model.Count</strong> de <strong>@Model.TotalCount</strong> cuotas
            - Pagina <strong>@Model.PageIndex</strong> de <strong>@Model.TotalPages</strong>
        </small>
    </div>

    <table class="table table-striped table-hover table-bordered align-middle">
        <thead class="table-info">
            <tr>
                <th>Venta</th>
                <th class="text-center">N°</th>
                <th>Vencimiento</th>
                <th>Pago</th>
                <th class="text-end">Monto</th>
                <th class="text-end">Interes</th>
                <th class="text-end">Pagado</th>
                <th class="text-end">Saldo</th>
                <th>Estado</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                var badge = c.EstadoCuota switch
                {
                    "Pagada" => "bg-success",
                    "Parcial" => "bg-info",
                    "Vencida" => "bg-danger",
                    _ => "bg-warning text-dark"
                };
                <tr>
                    <td>
                        <a asp-controller="Ventas" asp-action="Detalle" asp-route-id="@c.IdVenta">
                            @(c.Venta?.NumeroVenta ?? ("Venta #" + c.IdVenta))
                        </a>
                        @if (c.Venta?.Cliente is not null)
                        {
                            <div class="small text-muted">@c.Venta.Cliente.NombreCompleto</div>
                        }
                    </td>
                    <td class="text-center">@c.NumeroCuota</td>
                    <td>@(c.FechaVencimiento?.ToString("dd/MM/yyyy") ?? "-")</td>
                    <td>@(c.FechaPago?.ToString("dd/MM/yyyy") ?? "-")</td>
                    <td class="text-end">@c.MontoCuota.ToString("N2")</td>
                    <td class="text-end">@c.InteresMora.ToString("N2")</td>
                    <td class="text-end">@c.MontoPagado.ToString("N2")</td>
                    <td class="text-end fw-bold">@c.SaldoPendiente.ToString("N2")</td>
                    <td><span class="badge @badge">@(c.EstadoCuota ?? "-")</span></td>
                    <td class="text-center">
                        <a asp-action="Detalle" asp-route-id="@c.IdCuota"
                           class="btn btn-sm btn-info text-white" title="Ver detalle">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Editar" asp-route-id="@c.IdCuota"
                           class="btn btn-sm btn-warning" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="Eliminar" method="post" class="d-inline"
                              onsubmit="return confirm('Desea eliminar esta cuota?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@c.IdCuota" />
                            <button type="submit" class="btn btn-sm btn-danger" title="Eliminar">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Paginacion cuotas">
            <ul class="pagination justify-content-center">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="1"
                       asp-route-buscar="@ViewBag.Buscar" asp-route-idVenta="@ViewBag.IdVenta" asp-route-estadoCuota="@ViewBag.EstadoCuota">
                        <i class="bi bi-chevron-double-left"></i>
                    </a>
                </li>
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@(Model.PageIndex - 1)"
                       asp-route-buscar="@ViewBag.Buscar" asp-route-idVenta="@ViewBag.IdVenta" asp-route-estadoCuota="@ViewBag.EstadoCuota">
                        <i class="bi bi-chevron-left"></i> Anterior
                    </a>
                </li>
                @{
                    int inicio = Math.Max(1, Model.PageIndex - 2);
                    int fin = Math.Min(Model.TotalPages, inicio + 4);
                }
                @for (int i = inicio; i <= fin; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pagina="@i"
                           asp-route-buscar="@ViewBag.Buscar" asp-route-idVenta="@ViewBag.IdVenta" asp-route-estadoCuota="@ViewBag.EstadoCuota">@i</a>
                    </li>
                }
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@(Model.PageIndex + 1)"
                       asp-route-buscar="@ViewBag.Buscar" asp-route-idVenta="@ViewBag.IdVenta" asp-route-estadoCuota="@ViewBag.EstadoCuota">
                        Siguiente <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@Model.TotalPages"
                       asp-route-buscar="@ViewBag.Buscar" asp-route-idVenta="@ViewBag.IdVenta" asp-route-estadoCuota="@ViewBag.EstadoCuota">
                        <i class="bi bi-chevron-double-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
}
