@model VeterinariaGestion.Core.Entities.Tipo
@{
    ViewData["Title"] = "Detalle del Tipo";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
        <i class="bi bi-tag text-primary"></i> @Model.Descripcion
    </h2>
    <div class="d-flex gap-2">
        <a asp-action="Editar" asp-route-id="@Model.IdTipo" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Editar
        </a>
        <form asp-action="CambiarEstado" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.IdTipo" />
            <button type="submit"
                    class="btn @(Model.Estado == 1 ? "btn-outline-danger" : "btn-outline-success")">
                @if (Model.Estado == 1)
                {
                    <i class="bi bi-x-circle"></i>
                    <span>Desactivar</span>
                }
                else
                {
                    <i class="bi bi-check-circle"></i>
                    <span>Activar</span>
                }
            </button>
        </form>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>
</div>

<div class="row g-4">

    <!-- Info del tipo -->
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-info-circle"></i> Información
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">ID</dt>
                    <dd class="col-sm-7 text-muted">#@Model.IdTipo</dd>

                    <dt class="col-sm-5">Descripción</dt>
                    <dd class="col-sm-7"><strong>@Model.Descripcion</strong></dd>

                    <dt class="col-sm-5">Estado</dt>
                    <dd class="col-sm-7">
                        <span class="badge @(Model.Estado == 1 ? "bg-success" : "bg-secondary") fs-6">
                            @(Model.Estado == 1 ? "Activo" : "Inactivo")
                        </span>
                    </dd>

                    <dt class="col-sm-5">Productos</dt>
                    <dd class="col-sm-7">
                        <span class="badge bg-primary fs-6">
                            @Model.Productos.Count(p => p.Estado == 1) activos
                        </span>
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <!-- Productos del tipo -->
    <div class="col-md-8">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <span><i class="bi bi-box-seam"></i> Productos de este Tipo</span>
                <a asp-controller="Productos" asp-action="Crear"
                   class="btn btn-sm btn-light">
                    <i class="bi bi-plus"></i> Nuevo Producto
                </a>
            </div>
            <div class="card-body p-0">
                @{
                    var productosActivos = Model.Productos.Where(p => p.Estado == 1).ToList();
                }
                @if (!productosActivos.Any())
                {
                    <p class="text-muted p-3 mb-0">
                        <i class="bi bi-info-circle"></i>
                        No hay productos activos en este tipo.
                    </p>
                }
                else
                {
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Código</th>
                                <th>Nombre</th>
                                <th class="text-center">Stock</th>
                                <th class="text-end">P. Minorista</th>
                                <th class="text-end">P. Mayorista</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in productosActivos.OrderBy(p => p.Nombre))
                            {
                                <tr>
                                    <td class="text-muted small">@(p.Codigo ?? "-")</td>
                                    <td>
                                        <a asp-controller="Productos"
                                           asp-action="Detalle"
                                           asp-route-id="@p.IdProducto"
                                           class="text-decoration-none">
                                            @p.Nombre
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @(p.Stock <= 5 ? "bg-warning text-dark" : "bg-success")">
                                            @p.Stock
                                        </span>
                                    </td>
                                    <td class="text-end">$@p.PrecioMinorista.ToString("N2")</td>
                                    <td class="text-end">$@p.PrecioMayorista.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="2" class="text-end fw-bold">Total productos:</td>
                                <td class="text-center fw-bold">@productosActivos.Sum(p => p.Stock)</td>
                                <td colspan="2"></td>
                            </tr>
                        </tfoot>
                    </table>
                }
            </div>
        </div>
    </div>
</div>